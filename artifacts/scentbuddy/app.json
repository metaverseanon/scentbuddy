      "infoPlist": {
        "NSCameraUsageDescription": "ScentBuddy uses your camera to take photos of fragrance bottles so you can add them to your personal collection and identify scents.",
        "NSPhotoLibraryUsageDescription": "ScentBuddy accesses your photo library so you can select existing photos of fragrance bottles to add to your collection.",
        "NSPhotoLibraryAddUsageDescription": "ScentBuddy saves photos of fragrances to your photo library so you can keep a copy of your collection images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.scentbuddy"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
