{
  "expo": {
    "name": "ScentBuddy",
    "slug": "scentbuddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scentbuddy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d0b08"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.0kxdwz3d5g57j5m9vjhxs",
      "infoPlist": {
        "NSCameraUsageDescription": "ScentBuddy uses your camera to take photos of fragrance bottles so you can add them to your personal collection and identify scents.",
        "NSPhotoLibraryUsageDescription": "ScentBuddy accesses your photo library so you can select existing photos of fragrance bottles to add to your collection.",
        "NSPhotoLibraryAddUsageDescription": "ScentBuddy saves photos of fragrances to your photo library so you can keep a copy of your collection images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.0kxdwz3d5g57j5m9vjhxs"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#c49a6c"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "47299c20-5e8a-4485-88e5-01aa6b5403f9"
      }
    }
  }
}
